ANTHROPIC_API_KEY=sk-ant-...

# Path to a Lean 4 project with Mathlib built. Defaults to the bundled services/lean.
# That project must have completed `lake update && lake exe cache get && lake build` once.
LEAN_PROJECT_DIR=../lean

# Lean toolchain identifiers — flow into the verification cache key.
LEAN_VERSION=4.29.1
MATHLIB_VERSION=local

# Translator model. Sonnet-class for autoformalization.
TRANSLATOR_MODEL=claude-sonnet-4-6
DIAGNOSE_MODEL=claude-sonnet-4-6

# Lean process pool size (defaults to CPU count when blank).
LEAN_POOL_SIZE=

# Per-Lean-check timeout in seconds.
LEAN_TIMEOUT_SECONDS=30

# SQLite cache file.
CACHE_DB_PATH=./cache.db
CACHE_MAX_BYTES=524288000
